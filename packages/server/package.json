{
  "name": "@keyflare/server",
  "version": "0.1.0",
  "private": true,
  "description": "Keyflare API — Cloudflare Worker + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio --port 4983",
    "db:studio:remote": "DRIZZLE_REMOTE=true drizzle-kit studio --port 4983",
    "db:migrate:local": "wrangler d1 migrations apply keyflare-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply keyflare-db --remote"
  },
  "dependencies": {
    "@keyflare/shared": "*",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.19",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.0.0"
  }
}
