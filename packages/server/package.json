{
  "name": "@keyflare/server",
  "version": "0.1.0",
  "private": true,
  "description": "Keyflare API — Cloudflare Worker + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply keyflare-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply keyflare-db --remote"
  },
  "dependencies": {
    "@keyflare/shared": "*",
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.19",
    "@cloudflare/workers-types": "^4.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.0.0"
  }
}
