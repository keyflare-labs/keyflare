{
  "name": "@keyflare/server",
  "version": "0.1.0",
  "private": true,
  "description": "Keyflare API — Cloudflare Worker + D1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint src/ test/",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio --port 4983",
    "db:studio:remote": "DRIZZLE_REMOTE=true drizzle-kit studio --port 4983",
    "db:migrate:local": "wrangler d1 migrations apply keyflare --local",
    "db:migrate:remote": "wrangler d1 migrations apply keyflare --remote",
    "deploy": "wrangler deploy && pnpm run db:migrations:apply",
    "db:migrations:apply": "wrangler d1 migrations apply keyflare --remote",
    "cf-typegen": "wrangler types",
    "generate:openapi": "npx tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@keyflare/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "hono-openapi": "^1.3.0",
    "zod": "^3.25.76",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "~3.2.4",
    "wrangler": "^4.81.0"
  }
}
