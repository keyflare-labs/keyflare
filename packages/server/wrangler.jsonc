{
  "name": "keyflare",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  // D1 database binding
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "keyflare-db",
      "database_id": "local-dev-db",
      "migrations_dir": "migrations"
    }
  ]
}
