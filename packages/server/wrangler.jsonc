{
  "name": "keyflare",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-07",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true
    }
  },
  // D1 database binding
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "keyflare-db",
      "database_id": "local-dev-db",
      "migrations_dir": "migrations"
    }
  ]
}
