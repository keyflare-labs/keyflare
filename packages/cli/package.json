{
  "name": "@keyflare/cli",
  "version": "0.1.0",
  "description": "Keyflare CLI — kfl",
  "type": "module",
  "bin": {
    "kfl": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
