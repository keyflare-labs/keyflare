    "open": "^11.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@keyflare/server": "workspace:*",
    "@keyflare/shared": "workspace:*",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
