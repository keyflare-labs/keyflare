{
  "name": "@keyflare/cli",
  "version": "0.0.0",
  "description": "Keyflare CLI — kfl",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/keyflare-labs/keyflare.git"
  },
  "bin": {
    "kfl": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && tsx scripts/copy-server.ts",
    "build:fast": "tsup --no-dts && tsx scripts/copy-server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint src/"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@inquirer/prompts": "^8.4.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "debug": "^4.4.3",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "hono-openapi": "^1.3.0",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "wrangler": "^4.81.0",
    "zod": "^3.25.76",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@keyflare/shared": "workspace:*",
    "@types/debug": "^4.1.13",
    "@types/node": "^22.19.17",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
