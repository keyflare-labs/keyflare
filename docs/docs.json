{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Keyflare",
  "logo": {
    "light": "/assets/logo-light.svg",
    "dark": "/assets/logo-dark.svg"
  },
  "favicon": "/assets/favicon.svg",
  "colors": {
    "primary": "#F97316",
    "light": "#FB923C",
    "dark": "#EA580C"
  },
  "topbarLinks": [
    { "name": "GitHub", "url": "https://github.com/keyflare/keyflare" },
    { "name": "NPM", "url": "https://www.npmjs.com/package/@keyflare/cli" }
  ],
  "topbarCtaButton": {
    "name": "Get Started",
    "url": "/getting-started/quickstart"
  },
  "navbar": {
  "primary": {
    "type": "github",
    "href": "https://github.com/keyflare-labs/keyflare"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/introduction",
              "getting-started/quickstart",
              "getting-started/requirements"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/projects",
              "guides/secrets",
              "guides/api-keys",
              "guides/local-development",
              "guides/deployment"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/overview",
              "architecture/security",
              "architecture/encryption"
            ]
          },
          {
            "group": "Contributing",
            "pages": [
              "contributing/development",
              "contributing/testing"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "pages": [
          "cli/overview"
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ]
  },
  "api": {
    "baseUrl": "https://keyflare.YOUR_ACCOUNT.workers.dev"
  }
}
