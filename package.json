{
  "name": "keyflare",
  "version": "0.1.0",
  "private": true,
  "description": "Open Source Secrets Manager built entirely on Cloudflare",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --filter @keyflare/server dev",
    "studio": "pnpm --filter @keyflare/server db:studio",
    "setup": "pnpm install && pnpm --filter @keyflare/cli build:fast",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "types": "pnpm --filter @keyflare/server cf-typegen",
    "kfl": "tsx packages/cli/src/index.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "oxlint": "^0.18.0"
  }
}
