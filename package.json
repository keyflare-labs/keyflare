{
  "name": "keyflare",
  "version": "0.1.0",
  "private": true,
  "description": "Open Source Secrets Manager built entirely on Cloudflare",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --filter @keyflare/server dev",
    "dev:init": "tsx packages/cli/scripts/local-dev.ts init",
    "dev:server": "tsx packages/cli/scripts/local-dev.ts server",
    "studio": "pnpm --filter @keyflare/server db:studio",
    "setup": "pnpm install && pnpm --filter @keyflare/cli build:fast && pnpm install",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "types": "pnpm --filter @keyflare/server cf-typegen",
    "kfl": "tsx packages/cli/src/index.ts",
    "deploy": "pnpm -F @keyflare/server run deploy",
    "docs:dev": "cd docs && mintlify dev --port 3333",
    "docs:build": "mintlify build docs",
    "docs:openapi": "pnpm --filter @keyflare/server run generate:openapi",
    "cli:localpack": "pnpm i --frozen-lockfile && pnpm run build && pnpm pack ./packages/cli"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "mintlify": "^4.2.500",
    "oxlint": "^1.59.0"
  }
}
